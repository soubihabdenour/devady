APP_NAME=DevAdy
# Prefer APP_PASSWORD_HASH (recommended). Generate one with:
#   php -r 'echo password_hash("your-strong-password", PASSWORD_DEFAULT), "\n";'
APP_PASSWORD_HASH=
# Plaintext fallback — only used if APP_PASSWORD_HASH is empty. Do not commit a
# real value here in production.
APP_PASSWORD=change_me_to_a_strong_password
APP_URL=http://127.0.0.1:8811

# Lead notification email (where contact-form submissions are forwarded).
# Leave blank to disable email delivery (leads still get saved in the DB).
NOTIFY_EMAIL=
NOTIFY_FROM=noreply@devady.com

# Public invoice link signing secret. Generate with: openssl rand -hex 32
INVOICE_LINK_SECRET=
