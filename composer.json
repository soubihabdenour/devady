{
    "name": "devady/site",
    "description": "DevAdy — independent software studio: landing page, leads CRM, and invoicing.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-pdo_sqlite": "*",
        "ext-gd": "*",
        "ext-mbstring": "*",
        "dompdf/dompdf": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "platform-check": false
    },
    "scripts": {
        "serve": "php -S 127.0.0.1:8811 -t public",
        "migrate": "php bin/migrate.php"
    }
}
